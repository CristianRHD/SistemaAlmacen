    .modal-header { padding: 20px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; }
    .modal-body { padding: 20px; }
    .form-group { margin-bottom: 15px; }
    .form-label { display: block; margin-bottom: 6px; font-weight: 600; color: #374151; font-size: 0.9rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .form-input { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; box-sizing: border-box; }
    .modal-footer { padding: 20px; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; gap: 10px; }
    .btn-cancelar { background: #edf2f7; color: #4a5568; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; }
    .btn-guardar { background: #1414b8; color: white; border: none; padding: 10px 25px; border-radius: 8px; font-weight: bold; cursor: pointer; }
    .modal-cerrar { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #9ca3af; }
    .modal-titulo { margin: 0; font-size: 1.1rem; color: #1a202c; }

    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.8; } 100% { opacity: 1; } }
</style>

@code {
    private List<Producto> productos = new();
    private List<Producto> filteredProductos = new();
    private List<Proveedor> proveedores = new();
    private List<Proveedor> filteredProveedores = new();
    private List<Movimiento> historial = new();
    private Producto? productoSeleccionado;

    private string searchProducto = "", searchProveedor = "", productoNombreSeleccionado = "", proveedorNombreSeleccionado = "", error = "";
    private bool mostrarResultadosProducto, mostrarResultadosProveedor, mostrarAlertaVisual;
    private int productoId, proveedorId, existenciasActuales, umbralAvisoManual = 3;
    
    private int cantidadLotes = 1; // Cuántos lotes se reciben
    private int unidadesPorLoteReal = 1; // Cuántas unidades vienen en ESTE lote específico
    
    private decimal precioCompra;
    private bool cargando = true, mostrarModal, guardando, esEdicion;
    private int? movimientoEditandoId;
    private int cantidadOriginal;

    // BUSCADOR GLOBAL
    private string terminoBusqueda = "";

    private IEnumerable<Movimiento> MovimientosFiltrados
    {
        get
        {
            var entradas = historial.Where(m => m.Tipo == "Entrada").OrderByDescending(m => m.Fecha);
            
            if (string.IsNullOrWhiteSpace(terminoBusqueda))
                return entradas;

            var termino = terminoBusqueda.ToLower();
            
            return entradas.Where(m =>
                (m.Producto?.Nombre?.ToLower().Contains(termino) ?? false) ||
                (m.Producto?.Codigo?.ToLower().Contains(termino) ?? false) ||
                (m.Proveedor?.Nombre?.ToLower().Contains(termino) ?? false) ||
                (m.Proveedor?.RNC?.ToLower().Contains(termino) ?? false) ||
                (m.UsuarioResponsable?.ToLower().Contains(termino) ?? false) ||
                m.Fecha.ToString("dd/MM/yyyy").Contains(termino)
            );
        }
    }

    private void LimpiarBusqueda() => terminoBusqueda = "";

    private DialogModal DialogRef = default!;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        productos  = await ProductoService.ObtenerTodosAsync();
        proveedores = await Context.Proveedores.ToListAsync();
        historial  = await MovimientoService.ObtenerTodosAsync();
        cargando   = false;
    }

    // ── Búsquedas ──────────────────────────────────────────────────────────────
    private void OnSearchProducto(ChangeEventArgs e)
    {
        searchProducto = e.Value?.ToString() ?? "";
        mostrarResultadosProducto = !string.IsNullOrEmpty(searchProducto);
        filteredProductos = productos
            .Where(p => p.Nombre.Contains(searchProducto, StringComparison.OrdinalIgnoreCase) ||
                        p.Codigo.Contains(searchProducto, StringComparison.OrdinalIgnoreCase))
            .Take(5).ToList();
    }

    private void OnSearchProveedor(ChangeEventArgs e)
    {
        searchProveedor = e.Value?.ToString() ?? "";
        mostrarResultadosProveedor = !string.IsNullOrEmpty(searchProveedor);
        filteredProveedores = proveedores
            .Where(p => p.Nombre.Contains(searchProveedor, StringComparison.OrdinalIgnoreCase) ||
                        (p.RNC != null && p.RNC.Contains(searchProveedor)))
            .Take(5).ToList();
    }

    private void SeleccionarProducto(Producto p)
    {
        productoId = p.Id;
        productoSeleccionado = p;
        productoNombreSeleccionado = $"{p.Nombre} ({p.Codigo})";
        existenciasActuales = p.Existencias;
        unidadesPorLoteReal = p.UnidadesPorLote; // Auto-completar con el valor configurado
        mostrarResultadosProducto = false;
        ValidarAlertaManual(null);
        StateHasChanged();
    }

    private void SeleccionarProveedor(Proveedor prov)
    {
        proveedorId = prov.Id;
        proveedorNombreSeleccionado = prov.Nombre;
        mostrarResultadosProveedor = false;
    }

    private void ActualizarCalculos(ChangeEventArgs? e)
    {
        ValidarAlertaManual(e);
        StateHasChanged();
    }

    private void ValidarAlertaManual(ChangeEventArgs? e)
        => mostrarAlertaVisual = (existenciasActuales + cantidadLotes) <= umbralAvisoManual;

    // ── Modales ────────────────────────────────────────────────────────────────
    private void AbrirModalNuevo()
    {
        Limpiar();
        esEdicion = false;
        mostrarModal = true;
    }

    private void AbrirModalEditar(Movimiento mov)
    {
        Limpiar();
        esEdicion = true;
        movimientoEditandoId = mov.Id;
        cantidadOriginal = mov.Cantidad;

        productoId = mov.ProductoId;
        productoSeleccionado = mov.Producto;
        productoNombreSeleccionado = $"{mov.Producto?.Nombre} ({mov.Producto?.Codigo})";
        existenciasActuales = mov.Producto?.Existencias ?? 0;
        unidadesPorLoteReal = mov.Producto?.UnidadesPorLote ?? 1;

        if (mov.ProveedorId.HasValue)
        {
            proveedorId = mov.ProveedorId.Value;
            proveedorNombreSeleccionado = mov.Proveedor?.Nombre ?? "";
        }

        cantidadLotes = mov.Cantidad;
        precioCompra = mov.PrecioCompra ?? 0;
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;
    
    private void ResetProducto() 
    { 
        productoId = 0; 
        productoSeleccionado = null;
        searchProducto = ""; 
        existenciasActuales = 0;
        unidadesPorLoteReal = 1;
    }
    
    private void ResetProveedor() { proveedorId = 0; searchProveedor = ""; }

    private void Limpiar()
    {
        productoId = 0; proveedorId = 0; cantidadLotes = 1; precioCompra = 0;
        searchProducto = ""; searchProveedor = "";
        productoNombreSeleccionado = ""; proveedorNombreSeleccionado = "";
        productoSeleccionado = null;
        unidadesPorLoteReal = 1;
        error = ""; mostrarAlertaVisual = false;
        movimientoEditandoId = null; cantidadOriginal = 0;
    }

    // ── Guardar ────────────────────────────────────────────────────────────────
    private async Task Guardar()
    {
        if (productoId == 0 || proveedorId == 0) { error = "Complete los campos obligatorios."; return; }
        if (cantidadLotes <= 0) { error = "La cantidad debe ser mayor a cero."; return; }
        if (unidadesPorLoteReal <= 0) { error = "Las unidades por lote deben ser mayor a cero."; return; }

        guardando = true;
        error = "";

        try
        {
            if (esEdicion && movimientoEditandoId.HasValue)
            {
                await GuardarEdicion();
            }
            else
            {
                await GuardarNuevo();
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private async Task GuardarNuevo()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User.Identity?.Name ?? "Admin";

        var totalUnidades = cantidadLotes * unidadesPorLoteReal;
        var observaciones = $"Entrada: {cantidadLotes} lotes × {unidadesPorLoteReal} u/lote = {totalUnidades} unidades";

        bool res = await MovimientoService.RegistrarEntradaAsync(productoId, cantidadLotes, precioCompra, proveedorId, observaciones, user);
        if (res)
        {
            await Cargar();
            CerrarModal();
            await DialogRef.ShowSuccessAsync("Éxito", $"Se registraron {totalUnidades} unidades ({cantidadLotes} lotes)");
        }
    }

    private async Task GuardarEdicion()
    {
        var mov = await Context.Movimientos
            .Include(m => m.Producto)
            .FirstOrDefaultAsync(m => m.Id == movimientoEditandoId);

        if (mov == null) { error = "Movimiento no encontrado."; return; }

        int diferencia = cantidadLotes - cantidadOriginal;
        if (mov.Producto != null)
            mov.Producto.Existencias += diferencia;

        var totalUnidades = cantidadLotes * unidadesPorLoteReal;
        mov.ProductoId  = productoId;
        mov.ProveedorId = proveedorId;
        mov.Cantidad    = cantidadLotes;
        mov.PrecioCompra = precioCompra;
        mov.Observaciones = $"Entrada: {cantidadLotes} lotes × {unidadesPorLoteReal} u/lote = {totalUnidades} unidades";

        await Context.SaveChangesAsync();
        await Cargar();
        CerrarModal();
        await DialogRef.ShowSuccessAsync("Actualizado", "La entrada fue editada correctamente.");
    }

    // ── Eliminar ───────────────────────────────────────────────────────────────
    private async Task Eliminar(Movimiento mov)
    {
        if (await DialogRef.ShowConfirmAsync("Anular", "¿Restaurar cantidad anterior?", "Anular", "🗑️"))
        {
            var m = await Context.Movimientos
                .Include(x => x.Producto)
                .FirstOrDefaultAsync(x => x.Id == mov.Id);

            if (m != null && m.Producto != null)
            {
                m.Producto.Existencias -= m.Cantidad;
                Context.Movimientos.Remove(m);
                await Context.SaveChangesAsync();
                await Cargar();
            }
        }
    }
}