@page "/entrada"
@rendermode InteractiveServer
@using SistemaAlmacen.Models
@using SistemaAlmacen.Services
@using Microsoft.EntityFrameworkCore
@inject IMovimientoService MovimientoService
@inject ProductoService ProductoService
@inject SistemaAlmacen.Data.ApplicationDbContext Context
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<DialogModal @ref="DialogRef" />

<PageTitle>Entradas de Almacén - AlmaTrack</PageTitle>

<div class="entrada-container">
    <div class="entrada-header">
        <h1 class="entrada-titulo">📥 Gestión de Entradas</h1>
        <button @onclick="AbrirModalNuevo" class="btn-nuevo">
            ➕ Registrar Entrada
        </button>
    </div>

    @* BUSCADOR GLOBAL *@
    <div class="buscador-global">
        <div class="search-input-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" 
                   class="search-input" 
                   placeholder="Buscar por producto, código, proveedor, RNC o responsable..." 
                   @bind="terminoBusqueda" 
                   @bind:event="oninput" />
            @if (!string.IsNullOrWhiteSpace(terminoBusqueda))
            {
                <button class="clear-btn" @onclick="LimpiarBusqueda">✕</button>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(terminoBusqueda))
        {
            <p class="resultados-info">📊 Mostrando @MovimientosFiltrados.Count() de @historial.Count(m => m.Tipo == "Entrada") entradas</p>
        }
    </div>

    @if (cargando)
    {
        <div class="cargando-container">
            <p class="cargando-texto">⏳ Sincronizando registros...</p>
        </div>
    }
    else
    {
        <div class="tabla-container">
            @if (MovimientosFiltrados.Any())
            {
                <div class="tabla-wrapper">
                    <table class="tabla-entradas">
                        <thead class="tabla-head">
                            <tr>
                                <th>Fecha</th>
                                <th>Producto / Código</th>
                                <th>Proveedor / RNC</th>
                                <th>Lotes</th>
                                <th>Unidades/Lote</th>
                                <th>Total Unidades</th>
                                <th>Costo Por Lote</th>
                                <th>Responsable</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in MovimientosFiltrados)
                            {
                                var unidadesPorLote = mov.Producto?.UnidadesPorLote ?? 1;
                                var totalUnidades = mov.Cantidad * unidadesPorLote;
                                
                                <tr class="tabla-fila">
                                    <td class="tabla-td">@mov.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="tabla-td"><strong>@mov.Producto?.Nombre</strong><br/><small>@mov.Producto?.Codigo</small></td>
                                    <td class="tabla-td">@(mov.Proveedor?.Nombre ?? "N/A")<br/><small>@mov.Proveedor?.RNC</small></td>
                                    <td class="tabla-td"><span class="cantidad-badge">+@mov.Cantidad</span></td>
                                    <td class="tabla-td"><span style="font-weight:600;color:#4a5568">@unidadesPorLote</span></td>
                                    <td class="tabla-td"><strong style="color:#059669">@totalUnidades</strong></td>
                                    <td class="tabla-td">RD$ @(mov.PrecioCompra?.ToString("N2") ?? "0.00")</td>
                                    <td class="tabla-td"><span class="user-badge">👤 @mov.UsuarioResponsable</span></td>
                                    <td class="tabla-td">
                                        <div class="acciones-container">
                                            <button @onclick="() => AbrirModalEditar(mov)" title="Editar" class="btn-accion btn-editar">✏️</button>
                                            <button @onclick="() => Eliminar(mov)" title="Eliminar" class="btn-accion btn-eliminar">🗑️</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="sin-resultados">
                    <p class="sin-resultados-icon">🔍</p>
                    <p class="sin-resultados-texto">No se encontraron entradas que coincidan con "<strong>@terminoBusqueda</strong>"</p>
                    <button class="btn-limpiar-busqueda" @onclick="LimpiarBusqueda">Limpiar búsqueda</button>
                </div>
            }
        </div>
    }
</div>

@* MODAL NUEVO / EDITAR *@
@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal-contenido" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-titulo">@(esEdicion ? "✏️ Editar Entrada" : "📦 Registro de Nueva Recepción")</h3>
                <button @onclick="CerrarModal" class="modal-cerrar">×</button>
            </div>

            <div class="modal-body">
                @* BÚSQUEDA PRODUCTO *@
                <div class="form-group search-group">
                    <label class="form-label">Buscar Artículo *</label>
                    <input type="text" class="form-input" placeholder="Escriba nombre o código..."
                           @bind="searchProducto" @oninput="OnSearchProducto" />

                    @if (mostrarResultadosProducto && filteredProductos.Any() && productoId == 0)
                    {
                        <ul class="search-results">
                            @foreach (var p in filteredProductos)
                            {
                                <li @onclick="() => SeleccionarProducto(p)">
                                    <strong>@p.Codigo</strong> - @p.Nombre<br/>
                                    <small>Stock: @p.Existencias lotes (@p.UnidadesPorLote u/lote)</small>
                                </li>
                            }
                        </ul>
                    }
                    @if (productoId != 0)
                    {
                        <div class="selected-badge">✅ @productoNombreSeleccionado <span class="btn-remove" @onclick="ResetProducto">✕</span></div>
                    }
                </div>

                @* INFO DEL PRODUCTO *@
                @if (productoSeleccionado != null)
                {
                    <div class="info-producto">
                        <p>📦 <strong>Unidades por lote (configurado):</strong> @productoSeleccionado.UnidadesPorLote</p>
                        <p>📊 <strong>Stock actual:</strong> @productoSeleccionado.Existencias lotes = @(productoSeleccionado.Existencias * productoSeleccionado.UnidadesPorLote) unidades</p>
                    </div>
                }

                @* BÚSQUEDA PROVEEDOR *@
                <div class="form-group search-group">
                    <label class="form-label">Proveedor *</label>
                    <input type="text" class="form-input" placeholder="Escriba nombre o RNC..."
                           @bind="searchProveedor" @oninput="OnSearchProveedor" />

                    @if (mostrarResultadosProveedor && filteredProveedores.Any() && proveedorId == 0)
                    {
                        <ul class="search-results">
                            @foreach (var prov in filteredProveedores)
                            {
                                <li @onclick="() => SeleccionarProveedor(prov)">
                                    <strong>@prov.Nombre</strong> (RNC: @(prov.RNC ?? "S/R"))
                                </li>
                            }
                        </ul>
                    }
                    @if (proveedorId != 0)
                    {
                        <div class="selected-badge">✅ @proveedorNombreSeleccionado <span class="btn-remove" @onclick="ResetProveedor">✕</span></div>
                    }
                </div>

                @* CANTIDAD Y COSTO *@
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Cantidad de Lotes *</label>
                        <input type="number" @bind="cantidadLotes" min="1" class="form-input" @oninput="ActualizarCalculos" />
                        <small style="color:#64748b;font-size:0.8rem;margin-top:4px;display:block">
                            ¿Cuántos lotes recibiste?
                        </small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Unidades por Lote *</label>
                        <input type="number" @bind="unidadesPorLoteReal" min="1" class="form-input" @oninput="ActualizarCalculos" />
                        <small style="color:#64748b;font-size:0.8rem;margin-top:4px;display:block">
                            ¿Cuántas unidades en cada lote?
                        </small>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Costo por Lote RD$ *</label>
                    <input type="number" @bind="precioCompra" step="0.01" min="0" class="form-input" />
                    <small style="color:#64748b;font-size:0.8rem;margin-top:4px;display:block">
                        Precio de cada lote completo
                    </small>
                </div>

                @* RESUMEN MEJORADO *@
                @if (productoSeleccionado != null && cantidadLotes > 0 && unidadesPorLoteReal > 0)
                {
                    var totalUnidades = cantidadLotes * unidadesPorLoteReal;
                    var costoTotal = cantidadLotes * precioCompra;

                    <div class="resumen-entrada-detallado">
                        <h4 style="margin:0 0 12px 0;color:#1e40af;font-size:1rem">📊 RESUMEN DE ENTRADA</h4>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                            <div style="background:white;padding:12px;border-radius:8px;text-align:center">
                                <small style="color:#64748b;display:block;margin-bottom:5px">Lotes recibidos</small>
                                <strong style="font-size:1.4rem;color:#1e40af">@cantidadLotes</strong>
                            </div>
                            <div style="background:white;padding:12px;border-radius:8px;text-align:center">
                                <small style="color:#64748b;display:block;margin-bottom:5px">Unidades/Lote</small>
                                <strong style="font-size:1.4rem;color:#1e40af">@unidadesPorLoteReal</strong>
                            </div>
                            <div style="background:#059669;padding:15px;border-radius:8px;text-align:center;grid-column:1/-1">
                                <small style="color:#d1fae5;display:block;font-weight:600;margin-bottom:5px">TOTAL UNIDADES</small>
                                <strong style="font-size:2rem;color:white">@totalUnidades</strong>
                            </div>
                            <div style="background:#1414b8;padding:15px;border-radius:8px;text-align:center;grid-column:1/-1">
                                <small style="color:#dbeafe;display:block;font-weight:600;margin-bottom:5px">COSTO TOTAL</small>
                                <strong style="font-size:2rem;color:white">RD$ @costoTotal.ToString("N2")</strong>
                            </div>
                        </div>
                        <div style="margin-top:12px;text-align:center;background:white;padding:10px;border-radius:8px">
                            <small style="color:#475569">@cantidadLotes lotes × @unidadesPorLoteReal unidades = <strong style="color:#059669">@totalUnidades unidades totales</strong></small>
                        </div>
                    </div>
                }

                @* ALERTA SI DIFIERE DEL CONFIGURADO *@
                @if (productoSeleccionado != null && unidadesPorLoteReal != productoSeleccionado.UnidadesPorLote && unidadesPorLoteReal > 0)
                {
                    <div class="alerta-diferencia">
                        ℹ️ <strong>Nota:</strong> Este lote tiene @unidadesPorLoteReal unidades (diferente al estándar configurado: @productoSeleccionado.UnidadesPorLote).
                        Esto es normal para pedidos especiales o promociones.
                    </div>
                }

                @* UMBRAL VISUAL (solo en nuevo) *@
                @if (!esEdicion)
                {
                    <div class="form-group">
                        <label class="form-label" style="color: #1414b8;">🔔 Notificarme si después de esto quedan menos de:</label>
                        <input type="number" @bind="umbralAvisoManual" min="0" class="form-input border-blue" placeholder="Ej: 5 lotes" @oninput="ValidarAlertaManual" />
                    </div>

                    @if (mostrarAlertaVisual)
                    {
                        <div class="alert-warning-manual">
                            ⚠️ <strong>Atención:</strong> Según tu umbral (@umbralAvisoManual lotes), este producto quedará en estado crítico (@(existenciasActuales + cantidadLotes) lotes).
                        </div>
                    }
                }

                @if (esEdicion)
                {
                    <div class="nota-edicion">
                        📌 Al guardar, el stock del producto se recalculará con la nueva cantidad.
                    </div>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="error-mensaje">❌ @error</div>
                }

                <div class="modal-footer">
                    <button @onclick="CerrarModal" class="btn-cancelar">Cancelar</button>
                    <button @onclick="Guardar" disabled="@guardando" class="btn-guardar">
                        @(guardando ? "⏳ Procesando..." : (esEdicion ? "💾 Guardar Cambios" : "💾 Registrar Entrada"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

